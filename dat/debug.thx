$add : Int -> Int -> Int = \x = \y = x + y

$two = add 1 2

$pow : Int -> Int = \n =
    if n ?= 0 =>
        1
    else
        2 * pow (n - 1)

$pow22 = pow 322

$fib : Int -> Int = \n =
    if n ?= 0 =>
        0
    else if n ?= 1 =>
        1
    else
        (fib (n - 1)) + (fib (n - 2))

$fib10 = fib 10

$msg = "hello"

$answer = let x = 6 in x * 7

$complex = (1 + 2) * (3 - 4) + 5

$neg : Int -> Int = \x = -x
$a = neg 2
$b = !a

$application =
    (\x = \y = x + y) 1 2
