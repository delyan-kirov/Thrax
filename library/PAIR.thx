@mod PAIR

# \file PAIR.thx
# \info A generic two-field record. Field access is direct (`p.fst`,
#       `p.snd`); `pair` builds one without spelling the literal.

$ Pair : @struct =
	fst: `A,
	snd: `B,

$ pair : `A -> `B -> Pair `A `B = \a b =
	Pair.{ .fst = a, .snd = b }

$ swap : Pair `A `B -> Pair `B `A = \p =
	Pair.{ .fst = p.snd, .snd = p.fst }
